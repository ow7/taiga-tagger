{
  "manifest_version": 3,
  "name": "Taiga Custom",
  "version": "1.1",
  "description": "Customização para o Taiga.io",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["https://*.taiga.io/*", "https://taiga.io/*"],
  "content_scripts": [
    {
      "matches": ["https://*.taiga.io/*", "https://taiga.io/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Taiga Custom"
  }
}
